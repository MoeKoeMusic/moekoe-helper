{
  "manifest_version": 3,
  "name": "MoeKoe 插件示例助手",
  "plugin_id": "moekoe-helper-demo",
  "version": "1.1.0",
  "minversion": null,
  "moekoe": true,
  "author": {
    "name": "MoeKoe Music",
    "url": "https://music.moekoe.cn/"
  },
  "description": "用于演示 MoeKoe 插件的基础结构、消息通信与配置存储。",
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "MoeKoe 示例助手"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
